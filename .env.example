# ============================================================================
# Bhumi Propcity CRM — environment template
# Copy to `.env` (backend, local) and set the frontend var in Vercel.
# ============================================================================

# ---------------------------------------------------------------------------
# FRONTEND (Vite) — inlined into the bundle at BUILD time
# ---------------------------------------------------------------------------
# The API origin. Trailing /api/v1 is optional.
# Local dev: leave UNSET — the app falls back to http://localhost:5000.
# Production: set this in the VERCEL DASHBOARD (.env.production is gitignored,
# so Vercel never sees it from the repo). Redeploy after changing it.
VITE_API_URL=https://api.re.delpat.in

# ---------------------------------------------------------------------------
# BACKEND (Express on AWS)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/postgres
PORT=5000

# Set to 'true' when starting the API directly (tsx backend/src/index.ts).
START_SERVER=true
